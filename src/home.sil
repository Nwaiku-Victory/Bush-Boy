<div class="w-full h-full ff-arial flow-hidden flowy-scroll bg-black cl-white scroll-smooth">
    <header class="w-full p-10px px-20px flex jc-sp-ev ai-center pos-fixed top-0 zi-1 blur">
        <div class="flex flex-row gap-10 ai-center cl-white"> <img src="farm/IMG-20260325-WA0036.jpg" alt="logo" class="w-50px h-50px borr-40px"> <h2>IFCAF FARMS</h2> </div>
        <div class="none full-block lg-block">
            <a href="#home" class="text-capital td-none cl-white hover-cl-yellow fnt-w-bolder fnt-s-17px mx-10px">home</a>
            <a href="#about" class="text-capital td-none cl-white hover-cl-yellow fnt-w-bolder fnt-s-17px mx-10px">about us</a>
            <a href="#ourServices" class="text-capital td-none cl-white hover-cl-yellow fnt-w-bolder fnt-s-17px mx-10px">our services</a>
            <a href="#contact" class="text-capital td-none cl-white hover-cl-yellow fnt-w-bolder fnt-s-17px mx-10px">contact us</a>
        </div>
        <img id="menuIcon" src="./icn/menu.png" alt="search" class="none mid-block sm-block h-20px">
    </header>
    <div id="menus" class="w-full pos-fixed top-0 left-0 zi-1 mt-70px bg-black cl-white none flex-col ta-center">
        <p id="menuItem" class="w-full p-10px py-20px td-none text-capital cl-white hover-dark hover-cl-yellow fnt-w-bolder fnt-s-17px">home</p>
        <p id="menuItem" class="w-full p-10px py-20px td-none text-capital cl-white hover-dark hover-cl-yellow fnt-w-bolder fnt-s-17px">about us</p>
        <p id="menuItem" class="w-full p-10px py-20px td-none text-capital cl-white hover-dark hover-cl-yellow fnt-w-bolder fnt-s-17px">our services</p>
        <p id="menuItem" class="w-full p-10px py-20px td-none text-capital cl-white hover-dark hover-cl-yellow fnt-w-bolder fnt-s-17px">contact us</p>
    </div>

    <!-- hero section -->
    <div id="home" class="hero w-full min-h-full h-full">
        <div class="w-full min-h-full faded-80 cl-white p-15px flex jc-sp-ev ai-center wrap">
            <div class="w-900-full flex flex-col gap-20 ai-f-start p-20px">
                <b class="cl-gold">This is how</b>
                <h1 class="w-500-full fnt-s-70px text-capital">we farm with fun</h1>
                <p class="w-500-full fnt-s-17px cl-grey">Lorem ipsum dolor sit amet consectetur, adipisicing elit. Consequatur a temporibus quae esse veritatis eius impedit repellat ipsa? Ducimus vel dicta ab quibusdam sunt omnis nulla dolore ratione exercitationem vitae!</p>
                <button class="p-15px px-25px borr-5px bg-goldenrod cl-black fnt-w-bolder text-upper bor-2px bor-goldenrod hover-none hover-cl-white transition-0-5s">read more</button>
            </div>
        </div>
    </div>

    <!-- about section -->
    <div id="about" class="w-full min-h-full flex jc-center ai-center gap-75 wrap p-20px">
        <img src="farm/IMG-20260325-WA0037.jpg" alt="" class="w-400-full borr-10px">
        <div class="w-500-full flex flex-col gap-30 ai-f-start p-15px">
            <h1 class="fnt-s-50px">Have you enjoyed your form produce</h1>
            <p class="fnt-s-15px cl-grey">Lorem ipsum dolor sit amet consectetur adipisicing elit. Aperiam beatae assumenda numquam repellendus doloremque veniam autem quidem dignissimos iusto, incidunt saepe fugiat nulla in eveniet qui itaque expedita velit sapiente.</p>
